# ===== LLM API 配置 =====
# 支持 OpenAI SDK 格式的任意 LLM API
# 推荐使用阿里百炼平台 qwen-plus 模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于 40 轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== LLM 客户端模式（可选）=====
# 自动判断：api.openai.com → 使用 Responses API (responses.parse) 硬约束
#           其他（one-api/阿里百炼等）→ 使用 Chat Completions + json_schema 硬约束
# 两种模式都是 constrained decoding，100% 格式正确
# 也可以手动强制指定（true = 强制使用 Responses API，false = 强制使用 Chat Completions + json_schema）
# LLM_USE_STRUCTURED_OUTPUT=false

# ===== Neo4j + Graphiti 图谱配置 =====
# 本项目使用 Neo4j + Graphiti 作为知识图谱引擎
# Neo4j 安装指南见 graphiti/INSTALL.md
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ===== 加速 LLM 配置（可选）=====
# 如果不使用加速配置，请勿在 .env 中出现以下配置项
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
